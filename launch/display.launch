<launch>
  <arg
    name="model" />
  <param
    name="robot_description"
    textfile="$(find TH010-500 可拖拽外发模型(URDF)20260410)/urdf/TH010-500 可拖拽外发模型(URDF)20260410.urdf" />
  <node
    name="joint_state_publisher_gui"
    pkg="joint_state_publisher_gui"
    type="joint_state_publisher_gui" />
  <node
    name="robot_state_publisher"
    pkg="robot_state_publisher"
    type="robot_state_publisher" />
  <node
    name="rviz"
    pkg="rviz"
    type="rviz"
    args="-d $(find TH010-500 可拖拽外发模型(URDF)20260410)/urdf.rviz" />
</launch>